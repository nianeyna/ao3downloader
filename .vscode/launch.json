{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "uv debug",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/ao3downloader/main.py",
            "console": "integratedTerminal",
            "preLaunchTask": "uv sync"
        },
        {
            "name": "pytest debug",
            "type": "debugpy",
            "request": "launch",
            "module": "pytest",
            "console": "integratedTerminal",
            "preLaunchTask": "uv sync",
            "args": ["--cov=ao3downloader", "--cov-report", "term", "--cov-report", "xml:cov.xml"]
        },
        {
            "name": "fixture update",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/dev/refresh_fixtures.py",
            "console": "integratedTerminal",
            "preLaunchTask": "uv sync",
            "args": ["--only-new", "true"]
        },
        {
            "name": "fixture refresh",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/dev/refresh_fixtures.py",
            "console": "integratedTerminal",
            "preLaunchTask": "uv sync"
        }
    ]
}
